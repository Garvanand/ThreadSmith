# --- Shared AgentOS Ecosystem Keys ---
OPENROUTER_API_KEY=your_openrouter_key
AGENTOSINTERNAL_SERVICE_TOKEN=your_internal_mesh_token

# --- ThreadSmith Specific Integration Keys ---
# NOTE: These are NOT required for the synthetic-data MVP demo.
# They are required when configuring a live production ingestion webhook in Prompt 06.
ZENDESK_API_TOKEN=placeholder_for_zendesk_token
INTERCOM_ACCESS_TOKEN=placeholder_for_intercom_token

# --- Infra ---
REDIS_URL=redis://localhost:6379/1
POSTGRES_URL=postgresql://agentos:secret@localhost:5432/threadsmith
